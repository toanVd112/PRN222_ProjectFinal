<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEMS</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Boxicons -->
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <!-- Bootstrap & Custom CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="wrapper">
        <!-- SIDEBAR -->
        <aside id="sidebar">
            <div class="sidebar-brand">
                <i class='bx bx-cube-alt'></i> CEMS
            </div>
            <ul class="sidebar-menu">
                <li class="menu-header">Hệ thống</li>
                <li>
                    <a asp-controller="Home" asp-action="Index" class="active">
                        <i class='bx bx-grid-alt'></i> Dashboard
                    </a>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="menu-header">Quản trị (Admin)</li>
                    <li>
                        <a href="#">
                            <i class='bx bx-user-pin'></i> Quản lý Tài khoản
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class='bx bx-door-open'></i> Quản lý Phòng học
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class='bx bx-category'></i> Danh mục Thiết bị
                        </a>
                    </li>
                }
                
                @if (User.IsInRole("Technician") || User.IsInRole("Admin"))
                {
                    <li class="menu-header">Kỹ thuật (Technician)</li>
                    <li>
                        <a href="#">
                            <i class='bx bx-laptop'></i> Kho Thiết bị
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class='bx bx-transfer'></i> Luân chuyển
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class='bx bx-wrench'></i> Sự cố & Bảo trì
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class='bx bx-trash-alt'></i> Thanh lý
                        </a>
                    </li>
                }

                @if (User.IsInRole("Lecturer"))
                {
                    <li class="menu-header">Giảng viên (Lecturer)</li>
                    <li>
                        <a href="#">
                            <i class='bx bx-door-open'></i> Phòng của tôi
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class='bx bx-error'></i> Báo cáo sự cố
                        </a>
                    </li>
                }
            </ul>
        </aside>

        <!-- MAIN CONTENT WRAPPER -->
        <div id="content-wrapper">
            <!-- TOPBAR -->
            <header id="topbar">
                <div class="topbar-left">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="topbar-right">
                    <button class="topbar-btn">
                        <i class='bx bx-bell'></i>
                        <span class="badge-notification">3</span>
                    </button>
                    <div class="user-profile dropdown">
                        <div class="user-info text-end d-none d-md-block dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                            <span class="user-name">@(User.Identity?.Name ?? "Guest")</span>
                            <span class="user-role">@(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Guest")</span>
                        </div>
                        <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "Guest")&background=4F46E5&color=fff" alt="User Avatar">
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class='bx bx-log-out'></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <main id="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
